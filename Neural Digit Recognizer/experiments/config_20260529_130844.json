{
  "input_shape": [
    28,
    28,
    1
  ],
  "num_classes": 10,
  "filters": [
    32,
    64,
    128
  ],
  "dense_units": [
    256,
    128
  ],
  "dropout_rates": [
    0.5,
    0.3
  ],
  "use_residual": true,
  "use_se_attention": true,
  "se_ratio": 8,
