  "epochs": 15,
  "batch_size": 64,
  "initial_lr": 0.001,
  "min_lr": 1e-06,
  "label_smoothing": 0.1,
  "val_split": 0.2,
  "seed": 42,
  "early_stop_patience": 10,
  "reduce_lr_patience": 5,
  "reduce_lr_factor": 0.5,
  "use_ensemble": false,
  "ensemble_size": 3,
  "model_dir": "saved_model",
  "results_dir": "results",
  "experiments_dir": "experiments",
  "tensorboard_dir": "logs/tensorboard",
  "export_tflite": true,
  "export_onnx": true,
  "tflite_quantize": true
